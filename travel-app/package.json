{
  "name": "voyager",
  "version": "0.1.0",
  "scripts": {
    "android": "expo run:android",
    "ios": "expo run:ios",
    "ios:dev": "expo run:ios",
    "start": "expo start",
    "start:dev-client": "expo start --dev-client",
    "prebuild": "expo prebuild",
    "convex:dev": "convex dev",
    "convex:dev:local": "convex dev --local",
    "convex:deploy": "convex deploy",
    "seed": "convex run seed:seedDevData",
    "lan": "node scripts/lan-env.mjs",
    "lan:reset": "node scripts/lan-env.mjs --localhost",
    "init-template": "node scripts/init-from-template.mjs",
    "eas:init": "eas init",
    "eas:build:dev": "eas build -p ios --profile development",
    "eas:build:dev:sim": "eas build -p ios --profile development-simulator",
    "eas:build:preview": "eas build -p ios --profile preview",
    "eas:build:ios": "eas build -p ios --profile production",
    "eas:submit:ios": "eas submit -p ios --profile production",
    "eas:testflight": "eas build -p ios --profile production --auto-submit",
    "eas:update:preview": "eas update --branch preview",
    "eas:update:production": "eas update --branch production",
    "lint": "eslint \"**/*.{js,jsx,ts,tsx}\" && prettier -c \"**/*.{js,jsx,ts,tsx,json}\"",
    "format": "eslint \"**/*.{js,jsx,ts,tsx}\" --fix && prettier \"**/*.{js,jsx,ts,tsx,json}\" --write"
  },
  "dependencies": {
    "@convex-dev/auth": "^0.0.80",
    "@expo/vector-icons": "^15.0.2",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-navigation/bottom-tabs": "^7.2.0",
    "@react-navigation/native": "^7.0.14",
    "@tanstack/react-query": "^5.59.0",
    "clsx": "^2.1.1",
    "convex": "^1.17.0",
    "expo": "~55.0.23",
    "expo-asset": "~55.0.17",
    "expo-blur": "~55.0.14",
    "expo-constants": "~55.0.16",
    "expo-dev-client": "~55.0.32",
    "expo-device": "^55.0.17",
    "expo-font": "~55.0.7",
    "expo-image": "^55.0.10",
    "expo-image-picker": "^55.0.20",
    "expo-linear-gradient": "~55.0.13",
    "expo-linking": "~55.0.15",
    "expo-local-authentication": "~55.0.13",
    "expo-location": "^55.1.10",
    "expo-navigation-bar": "~55.0.12",
    "expo-notifications": "~55.0.22",
    "expo-router": "~55.0.14",
    "expo-secure-store": "~55.0.13",
    "expo-status-bar": "~55.0.6",
    "expo-system-ui": "~55.0.17",
    "expo-task-manager": "^55.0.16",
    "expo-updates": "~55.0.21",
    "lucide-react-native": "^0.511.0",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.6",
    "react-native-actions-sheet": "^0.9.7",
    "react-native-css-interop": "^0.1.22",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-health": "^1.19.0",
    "react-native-health-connect": "^3.5.0",
    "react-native-modal": "^14.0.0-rc.0",
    "react-native-purchases": "^10.1.1",
    "react-native-purchases-ui": "^10.1.1",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.23.0",
    "react-native-svg": "15.15.3",
    "react-native-worklets": "0.7.4",
    "tailwind-merge": "^3.0.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@babel/plugin-proposal-throw-expressions": "^7.25.9",
    "@types/react": "~19.2.10",
    "@typescript-eslint/eslint-plugin": "^7.7.0",
    "@typescript-eslint/parser": "^7.7.0",
    "eslint": "^8.57.0",
    "eslint-config-universe": "^12.0.1",
    "nativewind": "^2.0.11",
    "prettier": "^3.2.5",
    "prettier-plugin-tailwindcss": "^0.5.11",
    "tailwindcss": "3.3.2",
    "typescript": "~5.9.2"
  },
  "eslintConfig": {
    "extends": "universe/native",
    "root": true
  },
  "main": "expo-router/entry",
  "private": true
}
