# Convex deployment URL.
#
# Local backend (bun run convex:dev:local):
#   http://127.0.0.1:3210
#
# Cloud dev deployment (bun run convex:dev):
#   https://your-project.convex.cloud
EXPO_PUBLIC_CONVEX_URL=http://127.0.0.1:3210

# RevenueCat SDK public keys (one per platform). Get these from
# RevenueCat dashboard → Project settings → API keys. For paywall preview /
# sandbox development you can use the same `test_xxx` key on both platforms.
EXPO_PUBLIC_REVENUECAT_IOS_KEY=appl_xxxxxxxxxxxxxxxxxxxxxxxx
EXPO_PUBLIC_REVENUECAT_ANDROID_KEY=goog_xxxxxxxxxxxxxxxxxxxxxxxx
