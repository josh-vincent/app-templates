      "target": "assets/img/wallpaper-3.jpg"
    }
  ],
  "dependencies": [
    "expo-blur",
    "expo-linear-gradient",
    "expo-router",
    "expo-status-bar",
    "lottie-react-native",
    "react-native-safe-area-context"
