    "caloria-v2/icon",
    "caloria-v2/input",
    "caloria-v2/screen-contexts-theme-colors",
    "caloria-v2/themed-text"
  ],
  "category": "auth",
  "route": "/screens/signup",
  "kind": "screen",
  "traits": [
