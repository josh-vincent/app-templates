{
  "$schema": "../registry-item.schema.json",
  "name": "propia/screen-screens-chat-id",
  "type": "registry:screen",
  "template": "propia",
  "files": [
    {
      "path": "app/screens/chat/[id].tsx",
      "type": "registry:screen",
      "target": "app/screens/chat/[id].tsx"
    }
  ],
  "dependencies": [
    "expo-router",
    "react-native-actions-sheet",
    "react-native-safe-area-context"
  ],
  "registryDependencies": [
    "propia/action-sheet-themed",
    "propia/avatar",
    "propia/header",
    "propia/icon",
    "propia/page-loader",
    "propia/screen-contexts-theme-colors",
    "propia/themed-text"
  ],
  "category": "messaging",
  "route": "/screens/chat/[id]",
  "kind": "screen",
  "traits": [
    "soft-rounded",
    "native-adaptive"
  ]
}
