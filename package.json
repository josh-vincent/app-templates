{
  "name": "@jv/root",
  "private": true,
  "version": "0.0.0",
  "description": "Shared component library workspace for /Users/miniai/jv mobile apps.",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "catalog": "turbo run catalog",
    "showcase": "pnpm --filter @jv/showcase start",
    "codemod": "tsx scripts/codemod-imports.ts",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "sync-versions": "syncpack fix-mismatches"
  },
  "devDependencies": {
    "turbo": "^2.3.0",
    "prettier": "^3.3.3",
    "syncpack": "^13.0.0",
    "tsx": "^4.19.2",
    "typescript": "~5.9.2"
  },
  "pnpm": {
    "peerDependencyRules": {
      "allowedVersions": {
        "react": "*",
        "react-native": "*"
      }
    }
  }
}
