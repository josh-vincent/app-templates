{
  "$schema": "../schema/template.schema.json",
  "name": "voyage",
  "title": "Voyage — Flight Booking + AI Assistant",
  "description": "Flight-booking travel app with an AI assistant.",
  "source": {
    "repo": "josh-vincent/app-templates",
    "localPath": "./voyage"
  },
  "stack": {
    "expo": "55",
    "navigation": "expo-router",
    "styling": "nativewind",
    "backend": "expo-api-routes",
    "typescript": true,
    "usesSharedLibrary": false,
    "notable": [
      "ai",
      "lottie-react-native",
      "expo-notifications",
      "@tanstack/react-query"
    ]
  },
  "design": {
    "theming": "css-variables",
    "themeFiles": [
      "global.css",
      "contexts/ThemeColors.tsx",
      "tailwind.config.js"
    ],
    "darkMode": true
  },
  "layouts": [
    {
      "path": "app/(tabs)/(home)/_layout.tsx",
      "type": "stack",
      "group": "(tabs)/(home)"
    },
    {
      "path": "app/(tabs)/_layout.tsx",
      "type": "tabs",
      "group": "(tabs)"
    },
    {
      "path": "app/_layout.tsx",
      "type": "root",
      "group": null
    }
  ],
