{
  "$schema": "../schema/template.schema.json",
  "name": "evento",
  "title": "Evento — Events Discovery & Ticketing",
  "description": "A frontend-only React Native events template with 40+ components, mock data, and no backend required.",
  "source": {
    "repo": "ExpoStartup/evento",
    "localPath": "../evento"
  },
  "stack": {
    "expo": "57",
    "navigation": "expo-router",
    "styling": "nativewind",
    "backend": "none",
    "typescript": true,
    "usesSharedLibrary": false,
    "notable": [
      "react-native-maps",
      "lottie-react-native",
      "expo-notifications"
    ]
  },
  "design": {
    "theming": "css-variables",
    "themeFiles": [
      "global.css",
      "utils/color-theme.ts",
      "contexts/ThemeColors.tsx",
      "tailwind.config.js"
    ],
    "darkMode": true
  },
  "layouts": [
    {
      "path": "app/(tabs)/_layout.tsx",
      "type": "tabs",
      "group": "(tabs)"
    },
    {
      "path": "app/_layout.tsx",
      "type": "root",
      "group": null
    }
  ],
