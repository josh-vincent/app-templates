{
  "$schema": "../schema/template.schema.json",
  "name": "uniwind",
  "title": "Uniwind Starter — Component Showcase",
  "description": "A React Native template built with Expo, Uniwind (Tailwind CSS v4), and TypeScript. Includes 40+ components, dark/light theming, and a ready-to-use navigation structure.",
  "source": {
    "repo": "ExpoStartup/uniwind",
    "localPath": "../uniwind"
  },
  "stack": {
    "expo": "57",
    "navigation": "expo-router",
    "styling": "uniwind",
    "backend": "none",
    "typescript": true,
    "usesSharedLibrary": false,
    "notable": [
      "lottie-react-native",
      "expo-notifications"
    ]
  },
  "design": {
    "theming": "css-variables",
    "themeFiles": [
      "global.css",
      "contexts/ThemeColors.tsx"
    ],
    "darkMode": true
  },
  "layouts": [
    {
      "path": "app/(drawer)/(tabs)/_layout.tsx",
      "type": "drawer+tabs",
      "group": "(drawer)/(tabs)"
    },
    {
      "path": "app/(drawer)/_layout.tsx",
      "type": "drawer",
      "group": "(drawer)"
    },
    {
      "path": "app/_layout.tsx",
      "type": "root",
      "group": null
    }
  ],
  "screens": [
    {
      "id": "drawer:tabs:blank",
      "path": "app/(drawer)/(tabs)/blank.tsx",
      "route": "/blank",
      "kind": "tab",
      "category": "showcase",
      "tags": [
        "blank"
      ],
      "traits": [
        "soft-rounded",
        "flat"
      ],
      "components": [
        "AnimatedView",
        "Avatar",
        "Header",
        "Icon",
        "ListLink",
        "ThemeScroller",
        "ThemeToggle",
        "ThemedText"
      ],
      "modules": [],
      "packages": [
        "expo-router"
      ],
      "assets": []
    },
    {
