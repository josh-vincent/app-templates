{
  "$schema": "../schema/template.schema.json",
  "name": "propia",
  "title": "Propia — Property Booking Marketplace",
  "description": "Thank you for buying the Propia Booking template!",
  "source": {
    "repo": "ExpoStartup/propia",
    "localPath": "./propia"
  },
  "stack": {
    "expo": "55",
    "navigation": "expo-router",
    "styling": "nativewind",
    "backend": "none",
    "typescript": true,
    "usesSharedLibrary": false,
    "notable": [
      "react-native-maps",
      "lottie-react-native",
      "expo-notifications"
    ]
  },
  "design": {
    "theming": "css-variables",
    "themeFiles": [
      "global.css",
      "app/contexts/ThemeColors.tsx",
      "tailwind.config.js"
    ],
    "darkMode": true
  },
  "layouts": [
    {
      "path": "app/(tabs)/(home)/_layout.tsx",
      "type": "tabs+stack",
      "group": "(tabs)/(home)"
    },
    {
      "path": "app/(tabs)/_layout.tsx",
      "type": "tabs",
      "group": "(tabs)"
    },
    {
      "path": "app/_layout.tsx",
      "type": "root",
      "group": null
    }
  ],
