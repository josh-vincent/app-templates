{
  "$schema": "../schema/template.schema.json",
  "name": "drivo",
  "title": "Drivo — Ride Hailing",
  "description": "A React Native ride hailing app built with Expo, NativeWind, and TypeScript. Includes live Google Maps tracking with real road routing, animated search, driver simulation, ride tracking, and 40+ UI components.",
  "source": {
    "repo": "ExpoStartup/drivo",
    "localPath": "../drivo"
  },
  "stack": {
    "expo": "57",
    "navigation": "expo-router",
    "styling": "nativewind",
    "backend": "none",
    "typescript": true,
    "usesSharedLibrary": false,
    "notable": [
      "react-native-maps",
      "lottie-react-native",
      "expo-notifications"
    ]
  },
  "design": {
    "theming": "css-variables",
    "themeFiles": [
      "global.css",
      "utils/color-theme.ts",
      "contexts/ThemeColors.tsx",
      "tailwind.config.js"
    ],
    "darkMode": true
  },
  "layouts": [
    {
      "path": "app/(tabs)/_layout.tsx",
      "type": "tabs",
      "group": "(tabs)"
    },
    {
      "path": "app/_layout.tsx",
      "type": "root",
      "group": null
    }
  ],
