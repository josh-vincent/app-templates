    "theming": "css-variables",
    "themeFiles": [
      "global.css",
      "utils/color-theme.ts",
      "app/contexts/ThemeColors.tsx",
      "tailwind.config.js"
    ],
    "darkMode": true
  },
  "layouts": [
    {
      "path": "app/(drawer)/(tabs)/_layout.tsx",
      "type": "tabs",
      "group": "(drawer)/(tabs)"
    },
    {
      "path": "app/(drawer)/_layout.tsx",
      "type": "drawer",
      "group": "(drawer)"
    },
    {
      "path": "app/_layout.tsx",
      "type": "root",
      "group": null
    }
