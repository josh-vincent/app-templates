    "repo": "ExpoStartup/feedy",
    "localPath": "../feedy"
  },
  "stack": {
    "expo": "57",
    "navigation": "expo-router",
    "styling": "nativewind",
    "backend": "none",
    "typescript": true,
    "usesSharedLibrary": false,
    "notable": [
      "lottie-react-native",
      "expo-notifications"
    ]
  },
