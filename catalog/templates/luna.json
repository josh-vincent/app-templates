{
  "$schema": "../schema/template.schema.json",
  "name": "luna",
  "title": "Luna — AI Chat Assistant",
  "description": "A beautiful, production-ready AI chat template built with Expo and React Native.",
  "source": {
    "repo": "ExpoStartup/luna",
    "localPath": "../luna"
  },
  "stack": {
    "expo": "57",
    "navigation": "expo-router",
    "styling": "nativewind",
    "backend": "none",
    "typescript": true,
    "usesSharedLibrary": false,
    "notable": [
      "react-native-maps",
      "lottie-react-native",
      "expo-notifications"
    ]
  },
  "design": {
    "theming": "css-variables",
    "themeFiles": [
      "global.css",
      "utils/color-theme.ts",
      "app/contexts/ThemeColors.tsx",
      "tailwind.config.js"
    ],
    "darkMode": true
  },
  "layouts": [
    {
      "path": "app/(drawer)/_layout.tsx",
      "type": "drawer",
      "group": "(drawer)"
    },
    {
      "path": "app/_layout.tsx",
      "type": "root",
      "group": null
    }
  ],
