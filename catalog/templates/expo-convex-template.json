{
  "$schema": "../schema/template.schema.json",
  "name": "expo-convex-template",
  "title": "Expo + Convex Starter (FitStake base)",
  "description": "> **This is the product doc for the FitStake example app that ships with > the template** — not your project's product doc. When the template's > rename script runs, every occurrence of `FitStake` in this file is > substituted with your code name, which makes the doc nonsense if your > project isn't",
  "source": {
    "repo": "josh-vincent/app-templates",
    "localPath": "./expo-convex-template"
  },
  "stack": {
    "expo": "55",
    "navigation": "expo-router",
    "styling": "nativewind",
    "backend": "convex",
    "typescript": true,
    "usesSharedLibrary": true,
    "notable": [
      "react-native-purchases",
      "react-native-health",
      "expo-notifications",
      "@tanstack/react-query"
    ]
  },
  "design": {
    "theming": "css-variables",
    "themeFiles": [
      "global.css",
      "contexts/ThemeColors.tsx",
      "tailwind.config.js"
    ],
    "darkMode": true
  },
  "layouts": [
    {
      "path": "app/(auth)/_layout.tsx",
      "type": "stack",
      "group": "(auth)"
    },
    {
      "path": "app/(tabs)/(home)/_layout.tsx",
      "type": "stack",
      "group": "(tabs)/(home)"
    },
    {
      "path": "app/(tabs)/_layout.tsx",
      "type": "tabs",
      "group": "(tabs)"
    },
    {
      "path": "app/(tabs)/challenges/_layout.tsx",
      "type": "stack",
      "group": "(tabs)"
    },
    {
      "path": "app/_layout.tsx",
      "type": "root",
      "group": null
    },
    {
      "path": "app/friends/_layout.tsx",
      "type": "stack",
      "group": null
    },
    {
      "path": "app/onboarding/_layout.tsx",
      "type": "stack",
      "group": null
    }
  ],
