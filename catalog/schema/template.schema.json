{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/josh-vincent/app-templates/catalog/schema/template.schema.json",
  "title": "Template manifest",
  "description": "Self-describing manifest for one mobile app template. Generated by scripts/catalog/scan.mjs; curated fields (title, description, idea, tags, curation) survive rescans.",
  "type": "object",
  "required": ["name", "stack", "layouts", "screens", "components"],
  "properties": {
    "name": { "type": "string", "description": "Catalog id (registry key / filename)" },
    "title": { "type": ["string", "null"], "description": "Curated human title, e.g. 'Drivo — Ride Hailing'" },
    "description": { "type": ["string", "null"] },
    "idea": { "type": ["string", "null"], "description": "Curated one-line pitch of what this template is a base for" },
    "tags": { "type": "array", "items": { "type": "string" } },
    "source": {
      "type": "object",
      "properties": {
        "repo": { "type": ["string", "null"], "description": "owner/repo on GitHub" },
        "localPath": { "type": ["string", "null"], "description": "Checkout path relative to app-templates root" }
      }
    },
    "stack": {
      "type": "object",
      "properties": {
        "expo": { "type": ["string", "null"] },
        "navigation": { "type": "string" },
        "styling": { "type": "string", "enum": ["nativewind", "uniwind", "stylesheet"] },
        "backend": { "type": "string", "enum": ["none", "convex", "supabase", "expo-api-routes"] },
        "typescript": { "type": "boolean" },
        "usesSharedLibrary": { "type": "boolean", "description": "True when the template consumes @jv/* workspace packages" },
        "notable": { "type": "array", "items": { "type": "string" } }
      }
    },
    "design": {
      "type": "object",
      "description": "DESIGN layer: how theming/tokens work in this template",
      "properties": {
        "theming": { "type": "string" },
        "themeFiles": { "type": "array", "items": { "type": "string" } },
        "darkMode": { "type": "boolean" }
      }
    },
    "layouts": {
      "type": "array",
      "description": "LAYOUT layer: navigation shells (drawer/tabs/stack _layout.tsx files)",
      "items": {
        "type": "object",
        "required": ["path", "type"],
        "properties": {
          "path": { "type": "string" },
          "type": { "type": "string", "description": "root | drawer | tabs | stack | combinations like drawer+tabs" },
          "group": { "type": ["string", "null"] }
        }
      }
    },
    "screens": {
      "type": "array",
      "description": "SCREEN layer: functional screens, the primary catalog unit",
      "items": {
        "type": "object",
        "required": ["id", "path", "kind", "category"],
        "properties": {
          "id": { "type": "string" },
          "path": { "type": "string" },
          "route": { "type": "string" },
          "kind": { "type": "string", "enum": ["tab", "screen", "entry"] },
          "category": { "type": "string" },
          "description": { "type": "string" },
          "tags": { "type": "array", "items": { "type": "string" } },
          "components": { "type": "array", "items": { "type": "string" }, "description": "ELEMENT layer: components this screen imports" },
          "modules": { "type": "array", "items": { "type": "string" }, "description": "Supporting local modules (contexts, hooks, utils, lib, data)" },
          "packages": { "type": "array", "items": { "type": "string" }, "description": "npm packages the screen needs" },
          "assets": { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    "apiRoutes": { "type": "array", "items": { "type": "object" } },
    "components": {
      "type": "object",
      "description": "ELEMENT layer inventory, grouped by convention",
      "properties": {
        "elements": { "type": "array", "items": { "type": "string" } },
        "forms": { "type": "array", "items": { "type": "string" } },
        "layout": { "type": "array", "items": { "type": "string" } }
      }
    },
    "curation": {
      "type": "object",
      "description": "Per-screen manual overrides keyed by screen path; merged over generated data on rescan",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "category": { "type": "string" },
          "description": { "type": "string" },
          "tags": { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    "counts": { "type": "object" },
    "generatedBy": { "type": "string" }
  }
}
