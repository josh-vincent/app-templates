{
  "$comment": "Example remix plan — generated by `remix.mjs suggest`, then hand-tuned. Apply with: pnpm catalog:remix apply catalog/examples/dog-walking-marketplace.json --to ../pawgo --dry-run",
  "name": "pawgo",
  "idea": "dog walking marketplace with booking, payments and chat",
  "base": { "template": "propia", "layout": "app/(tabs)/_layout.tsx" },
  "design": { "from": "propia" },
  "style": { "screens": "style:soft-rounded", "buttons": "buttons:pill", "settings": "settings:toggles" },
  "fate": "mvp",
  "archetypes": ["marketplace"],
  "capabilities": ["skeleton-shell", "auth", "onboarding"],
  "screens": [
    { "template": "propia", "screen": "app/(tabs)/(home)/index.tsx", "category": "home" },
    { "template": "propia", "screen": "app/(tabs)/listings.tsx", "category": "commerce" },
    { "template": "propia", "screen": "app/screens/product-detail.tsx", "category": "detail" },
    { "template": "propia", "screen": "app/screens/booking-detail.tsx", "category": "commerce" },
    { "template": "propia", "screen": "app/screens/checkout.tsx", "category": "commerce" },
    { "template": "propia", "screen": "app/screens/earnings.tsx", "category": "commerce" },
    { "template": "propia", "screen": "app/(tabs)/calendar.tsx", "category": "planning" },
    { "template": "propia", "screen": "app/(tabs)/favorites.tsx", "category": "collections" },
    { "template": "feedy", "screen": "app/screens/chat/list.tsx", "category": "messaging" },
    { "template": "feedy", "screen": "app/screens/chat/[id].tsx", "category": "messaging" },
    { "template": "drivo", "screen": "app/screens/order-tracking.tsx", "as": "app/screens/walk-tracking.tsx", "category": "maps" },
    { "template": "propia", "screen": "app/screens/login.tsx", "category": "auth" },
    { "template": "propia", "screen": "app/screens/signup.tsx", "category": "auth" }
  ],
  "variants": [
    {
      "name": "lean",
      "notes": "MVP cut — no host earnings, no live tracking",
      "add": [],
      "remove": [
        { "template": "propia", "screen": "app/screens/earnings.tsx" },
        { "template": "drivo", "screen": "app/screens/order-tracking.tsx" }
      ]
    },
    {
      "name": "social",
      "notes": "Adds a community feed and walker profiles from Feedy",
      "add": [
        { "template": "feedy", "screen": "app/(drawer)/(tabs)/index.tsx", "as": "app/(tabs)/feed.tsx" },
        { "template": "feedy", "screen": "app/screens/user-profile.tsx" }
      ],
      "remove": []
    }
  ],
  "alternatives": ["voyage", "drivo", "evento"]
}
