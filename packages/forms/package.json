    "@jv/ui": "workspace:*"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-native": ">=0.74",
    "nativewind": ">=2",
    "react-native-reanimated": ">=3",
    "react-native-gesture-handler": ">=2",
    "react-native-modal": ">=13",
    "react-native-actions-sheet": ">=0.9",
    "@react-native-community/datetimepicker": ">=7",
    "expo-navigation-bar": ">=3",
    "lucide-react-native": ">=0.400.0"
  },
  "devDependencies": {
    "@jv/tsconfig": "workspace:*",
    "@jv/eslint-config": "workspace:*",
    "typescript": "~5.9.2"
  }
