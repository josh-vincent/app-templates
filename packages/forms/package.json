{
  "name": "@jv/forms",
  "version": "0.1.0",
  "private": true,
  "description": "Shared form inputs (Checkbox, Counter, DatePicker, FormTabs, Input, Select, Selectable, Slider, Switch, TextInput, TimePicker).",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "files": ["src"],
