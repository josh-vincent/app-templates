{
  "name": "@jv/ui",
  "version": "0.1.0",
  "private": true,
  "description": "Shared UI primitives for jv apps (Button, Card, Header, Avatar, FAB, Skeleton, etc).",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./theme": "./src/theme/index.ts",
    "./utils": "./src/utils/index.ts"
  },
  "files": [
    "src"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "eslint src --ext .ts,.tsx"
  },
  "dependencies": {
    "@jv/tokens": "workspace:*",
    "clsx": "^2.1.1",
    "tailwind-merge": "^2.5.4"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-native": ">=0.74",
    "nativewind": ">=2",
    "react-native-reanimated": ">=3",
    "react-native-svg": ">=15",
    "react-native-safe-area-context": ">=4",
    "react-native-actions-sheet": ">=0.9",
    "expo-blur": ">=13",
    "expo-linear-gradient": ">=13",
    "expo-router": ">=3",
    "expo-navigation-bar": ">=3",
    "lucide-react-native": ">=0.400.0",
    "@expo/vector-icons": ">=14",
    "@react-navigation/native": ">=6"
  },
  "devDependencies": {
    "@jv/tsconfig": "workspace:*",
    "@jv/eslint-config": "workspace:*",
    "@types/react": "~19.0.0",
    "@types/react-native": "~0.73.0",
    "typescript": "~5.9.2"
  }
}
